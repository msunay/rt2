{
  "name": "native-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:ci": "jest --config jest.config.js --ci",
    "test:single": "jest --config jest.config.js",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:watch": "jest --config jest.config.js --watch",
    "test:simple": "jest __tests__/standalone/logger.test.js",
    "lint": "expo lint"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^10.0.0",
    "@expo/vector-icons": "^14.1.0",
    "@hookform/resolvers": "^5.0.1",
    "@react-native-community/datetimepicker": "8.3.0",
    "@react-native-picker/picker": "2.11.0",
    "@reduxjs/toolkit": "^2.7.0",
    "@shopify/flash-list": "1.7.6",
    "date-fns": "^4.1.0",
    "expo": "~53.0.7",
    "expo-av": "~15.1.4",
    "expo-camera": "~16.1.6",
    "expo-checkbox": "~4.1.4",
    "expo-dev-client": "~5.1.8",
    "expo-font": "~13.3.1",
    "expo-image": "~2.1.6",
    "expo-linking": "~7.1.4",
    "expo-router": "~5.0.5",
    "expo-secure-store": "~14.2.3",
    "expo-splash-screen": "~0.30.8",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.7",
    "expo-web-browser": "~14.1.6",
    "mediasoup-client": "^3.10.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.55.0",
    "react-native": "0.79.2",
    "react-native-animated-nav-tab-bar": "^3.1.11",
    "react-native-countdown-circle-timer": "^3.2.1",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-loader-kit": "^2.0.8",
    "react-native-reanimated": "~3.17.3",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.10.0",
    "react-native-web": "~0.20.0",
    "react-native-webrtc": "^124.0.5",
    "react-native-webview": "13.13.5",
    "react-redux": "^9.2.0",
    "socket.io-client": "^4.8.1",
    "spin-delay": "^2.0.1",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.0.10",
    "jest": "^29.2.1",
    "jest-expo": "~53.0.4",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "typescript": "~5.8.3"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "collectCoverage": false,
    "collectCoverageFrom": [
      "**/*.{ts,tsx,js,jsx}",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/babel.config.js",
      "!**/expo-env.d.ts",
      "!**/.expo/**"
    ]
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-loader-kit",
          "react-native-webrtc",
          "@config-plugins/react-native-webrtc",
          "@hookform/resolvers",
          "expo-checkbox",
          "socket.io-client",
          "spin-delay",
          "yup"
        ]
      }
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": ["styled-components"]
  }
}
