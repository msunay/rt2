{
  "name": "rt2-client",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "npx @biomejs/biome lint --apply .",
    "lint-unsafe": "npx @biomejs/biome lint --apply-unsafe .",
    "lint-check": "npx @biomejs/biome lint .",
    "format": "npx @biomejs/biome format --write ",
    "test": "jest",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev": "eas build --profile development --platform all",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview": "eas build --profile preview --platform all",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production": "eas build --profile production --platform all"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^9.0.0",
    "@hookform/resolvers": "^3.3.4",
    "@react-native-community/datetimepicker": "8.0.1",
    "@react-native-picker/picker": "2.7.5",
    "@react-navigation/native": "^6.1.9",
    "@reduxjs/toolkit": "^2.0.1",
    "@rneui/base": "^4.0.0-rc.7",
    "@rneui/themed": "^4.0.0-rc.8",
    "@shopify/flash-list": "1.6.4",
    "cloudinary-react-native": "^0.0.2",
    "date-fns": "^3.3.1",
    "expo": "~51.0.11",
    "expo-av": "~14.0.5",
    "expo-camera": "~15.0.10",
    "expo-checkbox": "~3.0.0",
    "expo-constants": "~16.0.2",
    "expo-dev-client": "~4.0.15",
    "expo-font": "~12.0.5",
    "expo-image": "~1.12.11",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.15",
    "expo-secure-store": "~13.0.1",
    "expo-splash-screen": "~0.27.5",
    "expo-status-bar": "~1.12.1",
    "mediasoup-client": "^3.7.2",
    "react": "18.2.0",
    "react-hook-form": "^7.49.3",
    "react-native": "0.74.2",
    "react-native-animated-nav-tab-bar": "^3.1.10",
    "react-native-countdown-circle-timer": "^3.2.1",
    "react-native-loader-kit": "^2.0.8",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-webrtc": "^118.0.7",
    "react-redux": "^9.1.0",
    "socket.io-client": "^4.7.4",
    "spin-delay": "^2.0.0",
    "styled-components": "^4.4.1",
    "util": "^0.12.5",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@biomejs/biome": "^1.7.3",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.2.79",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.2",
    "react-test-renderer": "18.2.0",
    "typescript": "~5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "private": true
}
